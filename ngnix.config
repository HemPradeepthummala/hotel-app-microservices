events {}

http {

       upstream  booking-service {
           server booking:3000;
       }

       upstream  user-service {
              server auth:3000;
       }

         upstream  search-service {
                 server search:3000;
          }

    server {
        listen 80;

        location /api/users/ {
            proxy_pass http://user-service:8080;
        }

        location /api/bookings {
            proxy_pass http://booking-service:8080;

        }

        location /api/search/ {
            proxy_pass http://search-service:8080;
        }
    }
}